{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minmaxing.dev/schemas/opusminimax-run.schema.json",
  "title": "OpusMiniMax run artifact",
  "type": "object",
  "required": [
    "artifact_type",
    "run_id",
    "provider_profiles",
    "model_ids",
    "outcome_policy",
    "workflow_contract",
    "capacity",
    "packets",
    "verification",
    "failures",
    "retries",
    "final_confidence"
  ],
  "properties": {
    "artifact_type": {
      "const": "opusminimax-run"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "executor_provider": {
      "enum": ["minimax", "claude-sonnet", "anthropic"]
    },
    "model_profile": {
      "enum": ["minimax", "opussonnet", "sonnet", "opus", "default", "custom"]
    },
    "provider_profiles": {
      "type": "object",
      "required": ["planner", "executor"]
    },
    "model_ids": {
      "type": "object",
      "required": ["planner_requested", "executor_requested"]
    },
    "model_route": {
      "type": "object"
    },
    "outcome_policy": {
      "enum": ["verified-partial-or-blocked-with-repair", "advanced-engine-artifact"]
    },
    "workflow_contract": {
      "type": "object",
      "required": ["definitive_command", "route_role", "effectiveness_policy", "allowed_closeout_statuses", "blocked_requires_repair"],
      "properties": {
        "definitive_command": {"type": "boolean"},
        "route_role": {"type": "string"},
        "effectiveness_policy": {"type": "string"},
        "default_model_split": {"type": "string"},
        "allowed_closeout_statuses": {
          "type": "array",
          "items": {"type": "string"}
        },
        "blocked_requires_repair": {"type": "boolean"}
      }
    },
    "capacity": {
      "type": "object",
      "required": ["local_ceiling", "provider_ceiling", "task_packet_count", "safety_cap", "effective_concurrency"]
    },
    "packets": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "verification": {
      "type": "object",
      "required": ["status"]
    },
    "failures": {
      "type": "array"
    },
    "retries": {
      "type": "integer",
      "minimum": 0
    },
    "final_confidence": {
      "enum": ["high", "medium", "low"]
    }
  },
  "additionalProperties": true
}
