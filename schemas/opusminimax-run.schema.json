{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minmaxing.dev/schemas/opusminimax-run.schema.json",
  "title": "OpusMiniMax run artifact",
  "type": "object",
  "required": [
    "artifact_type",
    "run_id",
    "provider_profiles",
    "model_ids",
    "outcome_policy",
    "workflow_contract",
    "capacity",
    "packets",
    "verification",
    "failures",
    "retries",
    "final_confidence"
  ],
  "properties": {
    "artifact_type": {
      "const": "opusminimax-run"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "executor_provider": {
      "enum": ["minimax", "claude-sonnet", "anthropic"]
    },
    "model_profile": {
      "enum": ["minimax", "sonnetminimax", "opussonnet", "sonnet", "opus", "default", "custom"]
    },
    "provider_profiles": {
      "type": "object",
      "required": ["planner", "executor"]
    },
    "model_ids": {
      "type": "object",
      "required": ["planner_requested", "executor_requested"]
    },
    "model_route": {
      "type": "object"
    },
    "plan_mode": {
      "type": "object",
      "required": ["enabled", "policy", "checkpoint", "auto_approval", "does_not_replace"],
      "properties": {
        "enabled": {"type": "boolean"},
        "policy": {
          "enum": ["auto", "manual", "off"]
        },
        "checkpoint": {"type": "string"},
        "native_permission_mode": {"type": "string"},
        "native_permission_mode_status": {"type": "string"},
        "approval_scope": {"type": "string"},
        "auto_approval": {
          "type": "object",
          "required": ["default", "status", "execution_allowed_after", "blocks"],
          "properties": {
            "default": {"type": "boolean"},
            "status": {
              "enum": ["auto_approved_when_gates_pass", "manual_required", "disabled"]
            },
            "execution_allowed_after": {
              "type": "array",
              "items": {"type": "string"}
            },
            "blocks": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "does_not_replace": {
          "type": "array",
          "items": {"type": "string"}
        },
        "human_approval_required_when": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "outcome_policy": {
      "enum": ["verified-partial-or-blocked-with-repair", "advanced-engine-artifact"]
    },
    "workflow_contract": {
      "type": "object",
      "required": ["definitive_command", "route_role", "effectiveness_policy", "allowed_closeout_statuses", "blocked_requires_repair"],
      "properties": {
        "definitive_command": {"type": "boolean"},
        "route_role": {"type": "string"},
        "effectiveness_policy": {"type": "string"},
        "default_model_split": {"type": "string"},
        "allowed_closeout_statuses": {
          "type": "array",
          "items": {"type": "string"}
        },
        "blocked_requires_repair": {"type": "boolean"}
      }
    },
    "capacity": {
      "type": "object",
      "required": ["local_ceiling", "provider_ceiling", "task_packet_count", "safety_cap", "effective_concurrency"]
    },
    "packets": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "verification": {
      "type": "object",
      "required": ["status"]
    },
    "failures": {
      "type": "array"
    },
    "retries": {
      "type": "integer",
      "minimum": 0
    },
    "final_confidence": {
      "enum": ["high", "medium", "low"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "model_profile": {
            "const": "sonnetminimax"
          }
        },
        "required": ["model_profile"]
      },
      "then": {
        "required": ["executor_provider", "provider_profiles", "model_ids"],
        "properties": {
          "executor_provider": {
            "const": "minimax"
          },
          "provider_profiles": {
            "type": "object",
            "required": ["planner", "executor"],
            "properties": {
              "planner": {
                "type": "object",
                "properties": {
                  "anthropic_base_url": {
                    "not": {
                      "pattern": "api\\.minimax\\.io/anthropic"
                    }
                  },
                  "model": {
                    "not": {
                      "pattern": "MiniMax-M2\\.7-highspeed"
                    }
                  }
                }
              },
              "executor": {
                "type": "object",
                "properties": {
                  "anthropic_base_url": {
                    "const": "https://api.minimax.io/anthropic"
                  },
                  "model": {
                    "const": "MiniMax-M2.7-highspeed"
                  }
                },
                "required": ["anthropic_base_url", "model"]
              }
            }
          },
          "model_ids": {
            "type": "object",
            "required": ["planner_requested", "executor_requested"],
            "properties": {
              "planner_requested": {
                "const": "claude-sonnet-4-6"
              },
              "executor_requested": {
                "const": "MiniMax-M2.7-highspeed"
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
