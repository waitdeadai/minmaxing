# AgentCloseout physics runtime defaults for the public minmaxing harness.
# Copy to .claude/agentcloseout.env for local overrides. Do not add secrets.
AGENTCLOSEOUT_PROFILE="team-safe"
AGENTCLOSEOUT_PHYSICS="scripts/agentcloseout-physics.sh"
AGENTCLOSEOUT_RULES="tools/agentcloseout-physics/rules/closeout"
AGENTCLOSEOUT_RULE_PACK_HASH="sha256:2087c5cf648e4d0aa8690b02e97a0edd36cb13ea80d3a7423274b191dd9993b6"
AGENTCLOSEOUT_MODE="enforce"
AGENTCLOSEOUT_REQUIRE_CLEAN_ENV="0"
AGENTCLOSEOUT_LOOP_GUARD_MODE="release"
AGENTCLOSEOUT_LOOP_GUARD_REPAIR_LIMIT="1"
AGENTCLOSEOUT_LOOP_GUARD_STATE=".claude/agentcloseout-loop-guard.jsonl"
AGENTCLOSEOUT_TELEMETRY_MODE="off"
AGENTCLOSEOUT_TELEMETRY_QUEUE=""
