{
  "profile": "project-governance",
  "profileNotes": [
    "Provider-neutral trusted-local project settings.",
    "TRUSTED-LOCAL WARNING: this workspace defaults to bypassPermissions for the operator's solo workflow.",
    "Use .claude/settings.team-safe.example.json for shared, reviewed, client-visible, or less trusted work.",
    "Do not put Anthropic, Claude subscription, MiniMax, or other provider credentials in this file.",
    "Use ignored local profiles for planner/executor identity.",
    "Remote Control compatible: do not set CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC, DISABLE_TELEMETRY, disableRemoteControl, or provider auth variables in shared project settings.",
    "Agent View compatible: do not set disableAgentView or CLAUDE_CODE_DISABLE_AGENT_VIEW in shared project settings; live Agent View still starts manually with claude agents.",
    "Native /goal compatible: do not set disableAllHooks in shared project settings; workspace trust is runtime-only, and trusted-local bypassPermissions makes unattended /goal loops high-risk."
  ],
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_AUTO_COMPACT": "0",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebSearch",
      "mcp__MiniMax__web_search",
      "Bash(bash *.sh)"
    ],
    "deny": [
      "Read(./.claude/settings.local.json)",
      "Read(./.claude/*.local.json)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/govern-effectiveness.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agentcloseout-tamper-guard.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/govern-effectiveness.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/no-approval-sneak.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agentcloseout-tamper-guard.sh\"",
            "timeout": 5
